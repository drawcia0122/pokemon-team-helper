{
  "name": "pokemon-type-team-helper",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "dev": "npm run environment:export && next dev",
    "app": "node scripts/start-app.mjs",
    "build": "npm run environment:export && next build",
    "build:pages": "npm run environment:export && GITHUB_PAGES=true next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "data:validate": "tsx scripts/validateBuildArticles.ts && tsx scripts/validatePokemonContent.ts && tsx scripts/validateEnvironmentData.ts",
    "test:storage": "tsx scripts/testTeamStorage.ts",
    "test:import": "tsx scripts/testArticleImport.ts",
    "test:content": "tsx scripts/testPokemonContent.ts",
    "test:content-collection": "tsx scripts/testPokemonContentCollection.ts",
    "test:navigation": "tsx scripts/testSiteNavigation.ts",
    "test:team-ui": "tsx scripts/testTeamUi.ts",
    "test:team-selection": "tsx scripts/testTeamSelectionUi.ts",
    "test:coverage-analysis": "tsx scripts/testCoverageAnalysis.ts",
    "test:team-diagnostics": "tsx scripts/testTeamDiagnostics.ts",
    "test:team-threats": "tsx scripts/testTeamThreats.ts",
    "test:regulations": "tsx scripts/testRegulations.ts",
    "test:build-collection": "tsx scripts/testBuildArticleCollection.ts",
    "test:build-hatena": "tsx scripts/testHatenaBuildCollection.ts",
    "test:build-discovery": "tsx scripts/testBuildArticleDiscovery.ts",
    "test:build-migration": "tsx scripts/testParserMigration.ts",
    "test:build-ui": "tsx scripts/testBuildArticleUi.ts",
    "test:date": "tsx scripts/testDateFormat.ts",
    "test:pokemon-image": "tsx scripts/testPokemonImage.ts",
    "test:base-stats": "tsx scripts/testPokemonBaseStats.ts",
    "test:forms": "tsx scripts/testPokemonForms.ts",
    "test:availability": "tsx scripts/testPokemonAvailability.ts",
    "test:environment": "tsx scripts/testEnvironmentData.ts",
    "test:environment-ui": "tsx scripts/testEnvironmentUi.ts",
    "test:pages": "tsx scripts/testGitHubPages.ts",
    "collect:builds": "tsx scripts/collectBuildArticles.ts",
    "collect:builds:pokesol": "tsx scripts/collectBuildArticles.ts --source pokesol",
    "collect:builds:note": "tsx scripts/collectBuildArticles.ts --source note",
    "collect:builds:hatena": "tsx scripts/collectBuildArticles.ts --source hatena-blog",
    "collect:builds:hatena:dry-run": "tsx scripts/collectBuildArticles.ts --source hatena-blog --dry-run",
    "collect:builds:hatena:backfill": "tsx scripts/collectBuildArticles.ts --source hatena-blog --backfill",
    "discover:build-blogs": "tsx scripts/discoverBuildBlogs.ts",
    "discover:build-blogs:dry-run": "tsx scripts/discoverBuildBlogs.ts --dry-run",
    "collect:builds:reevaluate": "tsx scripts/collectBuildArticles.ts --reevaluate",
    "collect:builds:reevaluate:dry-run": "tsx scripts/collectBuildArticles.ts --reevaluate --dry-run",
    "report:build-extraction": "tsx scripts/reportBuildExtraction.ts",
    "collect:content": "tsx scripts/collectPokemonContent.ts",
    "collect:content:dry-run": "tsx scripts/collectPokemonContent.ts --dry-run",
    "collect:content:backfill": "tsx scripts/collectPokemonContent.ts --backfill",
    "collect:content:pokemon-go": "tsx scripts/collectPokemonContent.ts --source pokemon-go-official-rss",
    "environment:collect": "tsx scripts/collectEnvironmentData.ts",
    "environment:export": "tsx scripts/exportEnvironmentClientData.ts",
    "environment:localization:generate": "tsx scripts/generateEnvironmentLocalization.ts",
    "test:environment-localization": "tsx scripts/testEnvironmentLocalization.ts",
    "collect:builds:dry-run": "tsx scripts/collectBuildArticles.ts --dry-run",
    "check": "npm run data:validate && npm run test:storage && npm run test:import && npm run test:content && npm run test:content-collection && npm run test:navigation && npm run test:team-ui && npm run test:team-selection && npm run test:coverage-analysis && npm run test:team-diagnostics && npm run test:team-threats && npm run test:regulations && npm run test:build-collection && npm run test:build-hatena && npm run test:build-discovery && npm run test:build-migration && npm run test:build-ui && npm run test:date && npm run test:pokemon-image && npm run test:base-stats && npm run test:forms && npm run test:availability && npm run test:environment && npm run test:environment-localization && npm run test:environment-ui && npm run typecheck && npm run build",
    "data:fetch": "tsx scripts/fetchPokemonData.ts",
    "data:seed-season1": "node scripts/seedSeason1FromJapaneseList.mjs"
  },
  "dependencies": {
    "next": "15.5.20",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.10"
    }
  },
  "devDependencies": {
    "@types/node": "22.13.10",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "tsx": "4.19.3",
    "typescript": "5.8.2"
  }
}
